{
  "name": "consulting-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Internal consulting platform — CV database, team builder, proposals, presentations",
  "scripts": {
    "dev": "pnpm run --parallel dev:api dev:web",
    "dev:api": "pnpm --filter @consulting/api dev",
    "dev:web": "npm run dev --workspace=@consulting/web",
    "build": "pnpm run -r build",
    "db:generate": "pnpm --filter @consulting/api prisma:generate",
    "db:migrate": "pnpm --filter @consulting/api prisma:migrate",
    "db:seed": "pnpm --filter @consulting/api prisma:seed",
    "lint": "pnpm run -r lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "prisma": "^7.8.0"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0"
  }
}
