# Supabase: Project Settings → Database → Connection string
#
# DATABASE_URL = "Transaction" pooler (port 6543) — used by the running API
# DIRECT_URL   = "Session" or direct connection (port 5432) — used by Prisma migrate
#
# Replace [YOUR-PASSWORD] with your database password from Supabase.

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

PORT=3001
