generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AvailabilityStatus {
  AVAILABLE
  PARTIALLY_AVAILABLE
  UNAVAILABLE
}

enum TeamStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SkillCategory {
  KEY
  BUSINESS
  TECHNOLOGY
}

model Candidate {
  id               String             @id @default(uuid())
  firstName        String
  lastName         String
  email            String             @unique
  title            String
  yearsExperience  Int
  availability     AvailabilityStatus @default(AVAILABLE)
  education        String?
  summary          String?
  cvFilePath       String?
  profilePhotoUrl  String?
  skills           CandidateSkill[]
  projects         CandidateProject[]
  languages        CandidateLanguage[]
  industries       CandidateIndustry[]
  certificates     CandidateCertificate[]
  selectedClients  CandidateClient[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model CandidateSkill {
  id          String        @id @default(uuid())
  candidateId String
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String
  category    SkillCategory
  level       Int           @default(3)
  yearsUsed   Int           @default(0)

  @@unique([candidateId, name, category])
}

model CandidateLanguage {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  language    String
  level       String

  @@unique([candidateId, language])
}

model CandidateIndustry {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String

  @@unique([candidateId, name])
}

model CandidateCertificate {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String

  @@unique([candidateId, name])
}

model CandidateClient {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name        String

  @@unique([candidateId, name])
}

model CandidateProject {
  id           String    @id @default(uuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name         String
  description  String
  technologies String?
}

model Team {
  id          String       @id @default(uuid())
  name        String
  description String?
  status      TeamStatus   @default(DRAFT)
  members     TeamMember[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id                String                   @id @default(uuid())
  teamId            String
  team              Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sourceCandidateId String
  firstName         String
  lastName          String
  email             String
  title             String
  yearsExperience   Int
  availability      AvailabilityStatus       @default(AVAILABLE)
  education         String?
  summary           String?
  cvFilePath        String?
  profilePhotoUrl   String?
  role              String
  isLead            Boolean                  @default(false)
  joinedAt          DateTime                 @default(now())
  skills            TeamMemberSkill[]
  projects          TeamMemberProject[]
  languages         TeamMemberLanguage[]
  industries        TeamMemberIndustry[]
  certificates      TeamMemberCertificate[]
  selectedClients   TeamMemberClient[]

  @@unique([teamId, sourceCandidateId])
}

model TeamMemberSkill {
  id           String        @id @default(uuid())
  teamMemberId String
  teamMember   TeamMember    @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  name         String
  category     SkillCategory
  level        Int           @default(3)
  yearsUsed    Int           @default(0)

  @@unique([teamMemberId, name, category])
}

model TeamMemberLanguage {
  id           String     @id @default(uuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  language     String
  level        String

  @@unique([teamMemberId, language])
}

model TeamMemberIndustry {
  id           String     @id @default(uuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  name         String

  @@unique([teamMemberId, name])
}

model TeamMemberCertificate {
  id           String     @id @default(uuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  name         String

  @@unique([teamMemberId, name])
}

model TeamMemberClient {
  id           String     @id @default(uuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  name         String

  @@unique([teamMemberId, name])
}

model TeamMemberProject {
  id           String     @id @default(uuid())
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)
  name         String
  description  String
  technologies String?
}
