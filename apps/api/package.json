{
  "name": "@consulting/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "predev": "npm run build --workspace=@consulting/shared-kernel",
    "dev": "nest build && nest start --watch",
    "prebuild": "npm run build --workspace=@consulting/shared-kernel",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:backfill-photos": "tsx prisma/backfill-profile-photos.ts"
  },
  "dependencies": {
    "@consulting/shared-kernel": "*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "prisma": "^6.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
